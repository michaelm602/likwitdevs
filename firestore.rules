rules_version = '2';

service cloud.firestore {
  match /databases/{db}/documents {

    function isOwner() {
      return request.auth != null &&
             request.auth.uid in ['7u3Uund1CKRrtf4Pw0ehaLCI7WR2'];
    }

    match /projects/{doc} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /leads/{leadId} {

      function isValidLeadCreate() {
        return request.resource.data.keys().hasOnly([
          "name",
          "email",
          "replyTo",
          "website",
          "projectType",
          "rawIntent",
          "message",
          "rawMessage",
          "source",
          "sourcePage",
          "createdAt",
          "updatedAt",
          "status",
          "originPage",
          "landingPage",
          "referrer",
          "estimatedValue",
          "notes",
          "leadSource"
        ])
        && request.resource.data.status == "New"
        && request.resource.data.notes == ""
        && (
          !request.resource.data.keys().hasAny(["leadSource"]) ||
          request.resource.data.leadSource is string
        );
      }

      allow create: if isValidLeadCreate();
      allow read, update, delete: if isOwner();
    }

    match /analyticsEvents/{eventId} {

      function isValidAnalyticsEvent() {
        return request.resource.data.keys().hasOnly([
          "eventName",
          "pagePath",
          "sourcePage",
          "targetPath",
          "targetUrl",
          "projectSlug",
          "projectName",
          "serviceIntent",
          "leadId",
          "metadata",
          "createdAt",
          "originPage",
          "landingPage",
          "referrer",
          "sessionId"
        ])
        && request.resource.data.eventName is string
        && request.resource.data.sessionId is string
        && request.resource.data.metadata is map;
      }

      allow create: if isValidAnalyticsEvent();
      allow read: if isOwner();
      allow update, delete: if false;
    }
  }
}
